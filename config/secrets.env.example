# config/secrets.env.example
# ======================================================================================================
# 敏感配置模板 - 请勿直接提交到 Git
# 
# 使用方法:
# 1. 复制此文件为 secrets.env
#    cp config/secrets.env.example config/secrets.env
# 
# 2. 填写真实值（密码、密钥、证书等）
#    nano config/secrets.env
# 
# 3. secrets.env 已在 .gitignore 中排除，不会被提交
# ======================================================================================================

# ==============================
# 系统账户
# ==============================
# Root 密码（建议在安装后手动设置）
# ROOT_PASSWORD="YOUR_STRONG_PASSWORD"

# ==============================
# Aria2 下载工具
# ==============================
# RPC 访问密钥（用于远程控制）
# 生成方法: openssl rand -base64 32
ARIA2_RPC_SECRET="YOUR_RPC_SECRET_CHANGE_ME"

# WebDAV 用户名和密码
ARIA2_WEBDAV_USER="webdav"
ARIA2_WEBDAV_PASSWORD="YOUR_WEBDAV_PASSWORD_CHANGE_ME"

# 下载目录
ARIA2_DOWNLOAD_DIR="$HOME/Downloads"

# 配置目录
ARIA2_CONFIG_DIR="$HOME/.config/aria2"

# ==============================
# OpenVPN
# ==============================
# VPN 服务器地址
OPENVPN_SERVER="myac.dynamic-dns.net"

# VPN 端口
OPENVPN_PORT="1194"

# CA 证书（从路由器或 VPN 管理员处获取）
# 多行内容使用 $'...' 语法
OPENVPN_CA_CERT=$'-----BEGIN CERTIFICATE-----
YOUR_CA_CERTIFICATE_HERE
请从真实的 .ovpn 文件中复制 <ca> 标签内的内容
-----END CERTIFICATE-----'

# 客户端证书
OPENVPN_CLIENT_CERT=$'-----BEGIN CERTIFICATE-----
YOUR_CLIENT_CERTIFICATE_HERE
请从真实的 .ovpn 文件中复制 <cert> 标签内的内容
-----END CERTIFICATE-----'

# 私钥
OPENVPN_CLIENT_KEY=$'-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE
请从真实的 .ovpn 文件中复制 <key> 标签内的内容
-----END PRIVATE KEY-----'

# ==============================
# NextCloud
# ==============================
# NextCloud 服务器地址
NEXTCLOUD_SERVER="nc.nl.tab.digital"

# 自动登录（可选）
# NEXTCLOUD_USERNAME="your_username"
# NEXTCLOUD_PASSWORD="your_password"

# ==============================
# Git 配置
# ==============================
GIT_USER_NAME="David Liu"
GIT_USER_EMAIL="liu_dong@outlook.com"

# ==============================
# SSH 密钥
# ==============================
# SSH 私钥路径（如需自动部署）
# SSH_PRIVATE_KEY_PATH="$HOME/.ssh/id_rsa"

# ==============================
# 备份位置
# ==============================
# 外部存储挂载点
BACKUP_MOUNT_POINT="/media/$USER/Data"

# 备份目录
BACKUP_DIR="$BACKUP_MOUNT_POINT/ubuntu_backups"

# ==============================
# 自定义路径
# ==============================
# 如需覆盖 config.ini 中的默认值，在此定义

# 示例: 自定义 programs 目录位置
# PROGRAMS_DIR="/opt/programs"

# 示例: 自定义 NextCloud 安装位置
# NEXTCLOUD_INSTALL_DIR="/opt/nextcloud"

# ==============================
# 调试选项
# ==============================
# 开启调试模式（显示详细信息）
# DEBUG_MODE=true

# 干跑模式（不实际执行，仅测试）
# DRY_RUN=true

# ==============================
# 注意事项
# ==============================
# 1. 此文件包含敏感信息，请妥善保管
# 2. 不要将 secrets.env 提交到公开仓库
# 3. 定期备份到安全位置: /media/$USER/Data/ubuntu_install_private/
# 4. 如果不需要某项配置，可以注释掉（#）或删除
# 5. 变量值中包含特殊字符时，使用引号包裹
